{
  "name": "cais-indicacoes",
  "version": "0.1.0",
  "private": true,
  "description": "MVP de Programa de Indicações para Consórcios — monorepo",
  "scripts": {
    "dev": "pnpm --filter api dev",
    "build": "pnpm --filter api build",
    "docker:dev": "docker compose -f docker/docker-compose.dev.yml up -d",
    "docker:dev:down": "docker compose -f docker/docker-compose.dev.yml down",
    "docker:dev:reset": "docker compose -f docker/docker-compose.dev.yml down -v",
    "docker:prod": "docker compose -f docker/docker-compose.prod.yml up -d --build",
    "docker:prod:down": "docker compose -f docker/docker-compose.prod.yml down",
    "db:migrate": "pnpm --filter api prisma migrate dev",
    "db:seed": "pnpm --filter api prisma db seed",
    "db:studio": "pnpm --filter api prisma studio"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0"
}
