# =============================================================================
# CAIS Indicações — frontend em PRODUÇÃO (Vercel)
# =============================================================================
#
# Configure estas variáveis no painel da Vercel:
#   Project → Settings → Environment Variables → Production
#
# Não commite arquivos .env com secrets. Este arquivo é apenas referência.
# =============================================================================

# URL pública da API na VPS (NGINX → proxy_pass → localhost:3001)
# Deve terminar em /api/v1 (sem barra final)
VITE_API_URL=https://api.seudominio.com.br/api/v1

# Mesmo token definido em TV_API_TOKEN no .env da VPS
VITE_TV_TOKEN=SUBSTITUA_PELO_MESMO_TOKEN_DA_API

# Som opcional na tela TV: festa | coins | success | none
# VITE_TV_SOUND=festa

# Supabase (boilerplate — o CRM usa a API Fastify, pode deixar vazio)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=
