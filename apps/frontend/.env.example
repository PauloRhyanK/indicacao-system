# URL base da API Fastify
# Dev local: proxy Vite em vite.config.ts — use caminho relativo
VITE_API_URL=/api/v1
# Produção (Vercel): URL pública do backend na VPS, ex.:
# VITE_API_URL=https://api.seudominio.com.br/api/v1

# Token opcional para presets/som na tela TV (header X-TV-Token)
# VITE_TV_TOKEN=
# VITE_TV_SOUND=festa
