generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReferrerType {
  USER
  LEAD
}

enum OpportunityGrade {
  BAIXO
  MEDIO
  ALTO
  EXTREMO
}

enum CampaignRewardType {
  RESPONSAVEL
  CO_VENDEDOR
  FIRST_CONTACT
  REFERRAL
  CLIENT
}

enum ClientRewardChoice {
  CASHBACK
  TRAVEL_VOUCHER
}

enum CampaignRewardStatus {
  PENDING
  PAID
  CANCELLED
}

model User {
  id                  String    @id @default(uuid()) @db.Uuid
  name                String
  email               String    @unique
  phone               String?
  passwordHash        String    @map("password_hash")
  mustChangePassword  Boolean   @default(false) @map("must_change_password")
  personalDailyTarget Decimal?  @map("personal_daily_target") @db.Decimal(14, 2)
  createdAt           DateTime  @default(now()) @map("created_at")
  deletedAt           DateTime? @map("deleted_at")

  leadsAsResponsavel     Lead[]     @relation("LeadResponsavel")
  leadsAsCoVendedor      Lead[]     @relation("LeadCoVendedor")
  leadsCreated           Lead[]     @relation("LeadCreatedBy")
  leadsFirstContact      Lead[]     @relation("LeadFirstContact")
  purchasesAsResponsavel Purchase[]     @relation("PurchaseResponsavel")
  campaignRewardsPaid    CampaignReward[] @relation("CampaignRewardPaidBy")
  userRoles              UserRole[]
  aliases            UserAlias[]

  @@index([deletedAt])
  @@map("users")
}

model UserAlias {
  id              String   @id @default(uuid()) @db.Uuid
  aliasNormalized String   @unique @map("alias_normalized")
  aliasRaw        String   @map("alias_raw")
  userId          String   @map("user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_aliases")
}

model Permission {
  key         String  @id
  label       String
  description String?
  groupName   String  @map("group_name")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model Role {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  isSystem  Boolean  @default(false) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model RolePermission {
  roleId         String @map("role_id") @db.Uuid
  permissionKey  String @map("permission_key")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionKey], references: [key], onDelete: Cascade)

  @@id([roleId, permissionKey])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model LeadStatus {
  id   String @id @default(uuid()) @db.Uuid
  slug String @unique
  name String

  leads Lead[]

  @@map("lead_statuses")
}

model ConsortiumType {
  id   String @id @default(uuid()) @db.Uuid
  slug String @unique
  name String

  purchases Purchase[]

  @@map("consortium_types")
}

model Lead {
  id                 String    @id @default(uuid()) @db.Uuid
  externalCode       String?   @unique @map("external_code")
  name               String
  phone              String?
  responsavelId      String?   @map("responsavel_id") @db.Uuid
  coVendedorId       String?   @map("co_vendedor_id") @db.Uuid
  createdById        String?   @map("created_by_id") @db.Uuid
  firstContactId     String?   @map("first_contact_id") @db.Uuid
  salesStatusId      String?           @map("sales_status_id") @db.Uuid
  opportunityGrade   OpportunityGrade? @map("opportunity_grade")
  notes              String?
  offeredAmount      Decimal?  @map("offered_amount") @db.Decimal(15, 2)
  closedAmount       Decimal?  @map("closed_amount") @db.Decimal(15, 2)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  salesStatus      LeadStatus? @relation(fields: [salesStatusId], references: [id], onDelete: SetNull)
  responsavel      User?       @relation("LeadResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  coVendedor       User?       @relation("LeadCoVendedor", fields: [coVendedorId], references: [id], onDelete: SetNull)
  createdBy        User?       @relation("LeadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  firstContact     User?       @relation("LeadFirstContact", fields: [firstContactId], references: [id], onDelete: SetNull)
  purchases        Purchase[]
  referralsAsLead  Referral[]  @relation("ReferredLead")

  @@index([externalCode])
  @@index([salesStatusId])
  @@index([responsavelId])
  @@index([coVendedorId])
  @@index([createdById])
  @@index([firstContactId])
  @@index([deletedAt])
  @@map("leads")
}

model Referral {
  id             String       @id @default(uuid()) @db.Uuid
  referredLeadId String       @map("referred_lead_id") @db.Uuid
  referrerType   ReferrerType @map("referrer_type")
  referrerId     String       @map("referrer_id") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at")

  referredLead Lead @relation("ReferredLead", fields: [referredLeadId], references: [id], onDelete: Cascade)

  @@unique([referredLeadId])
  @@index([referrerType, referrerId])
  @@map("referrals")
}

model Purchase {
  id               String    @id @default(uuid()) @db.Uuid
  leadId           String    @map("lead_id") @db.Uuid
  responsavelId    String?   @map("responsavel_id") @db.Uuid
  consortiumTypeId String?   @map("consortium_type_id") @db.Uuid
  amount           Decimal   @db.Decimal(15, 2)
  purchaseDate     DateTime  @map("purchase_date")
  boletoPaid       Boolean   @default(false) @map("boleto_paid")
  createdAt        DateTime  @default(now()) @map("created_at")
  deletedAt        DateTime? @map("deleted_at")

  lead           Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  responsavel    User?           @relation("PurchaseResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  consortiumType ConsortiumType? @relation(fields: [consortiumTypeId], references: [id], onDelete: SetNull)
  campaignRewards CampaignReward[]

  @@index([leadId])
  @@index([responsavelId])
  @@index([consortiumTypeId])
  @@index([deletedAt])
  @@map("purchases")
}

model CampaignReward {
  id            String               @id @default(uuid()) @db.Uuid
  purchaseId    String               @map("purchase_id") @db.Uuid
  type          CampaignRewardType
  referralLevel Int                  @default(0) @map("referral_level")
  recipientType ReferrerType?        @map("recipient_type")
  recipientId   String?              @map("recipient_id") @db.Uuid
  recipientName String               @map("recipient_name")
  amount        Decimal?             @db.Decimal(15, 2)
  clientChoice  ClientRewardChoice?  @map("client_choice")
  status        CampaignRewardStatus @default(PENDING)
  amountStale   Boolean              @default(false) @map("amount_stale")
  paidAt        DateTime?            @map("paid_at")
  paidById      String?              @map("paid_by_id") @db.Uuid
  notes         String?
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  paidBy   User?    @relation("CampaignRewardPaidBy", fields: [paidById], references: [id], onDelete: SetNull)

  @@unique([purchaseId, type, referralLevel])
  @@index([purchaseId])
  @@index([status])
  @@map("campaign_rewards")
}

model Goal {
  id            String   @id @default(uuid()) @db.Uuid
  targetAmount  Decimal  @map("target_amount") @db.Decimal(15, 2)
  currentAmount Decimal  @default(0) @map("current_amount") @db.Decimal(15, 2)
  startDate     DateTime @map("start_date")
  endDate       DateTime @map("end_date")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([startDate, endDate])
  @@map("goals")
}

model MetaDailyDefault {
  id        String   @id @default(uuid()) @db.Uuid
  weekday   Int      @unique
  amount    Decimal  @db.Decimal(15, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("meta_daily_defaults")
}

model MetaDailyOverride {
  id         String    @id @default(uuid()) @db.Uuid
  date       DateTime  @unique @db.Date
  amount     Decimal?  @db.Decimal(15, 2)
  presetSlug String?   @map("preset_slug")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("meta_daily_overrides")
}
