# =============================================================================
# CAIS Indicações — variáveis de PRODUÇÃO (VPS / Docker)
# =============================================================================
#
# Uso na VPS:
#   cp .env.production.example .env
#   nano .env          # preencha os valores reais
#   pnpm docker:prod   # sobe Postgres + API + pgAdmin (subdomínio db.*)
#
# Depois do primeiro deploy, rode o seed (domínios + admin + RBAC):
#   docker exec -it cais_api_prod npx prisma db seed
#
# O .env deve ficar na RAIZ do projeto (mesmo nível de package.json).
# Ao usar -f docker/docker-compose.prod.yml, passe explicitamente:
#   docker compose --env-file .env -f docker/docker-compose.prod.yml up -d
#
# Senhas com $ no valor precisam dobrar o caractere: Minha$$Senha
# =============================================================================

# Rede Docker compartilhada com o Nginx Proxy Manager (container global-proxy).
# Descubra o nome na VPS:
#   docker inspect global-proxy --format '{{range $k,$v := .NetworkSettings.Networks}}{{$k}} {{end}}'
PROXY_NETWORK=proxy-network

# --- PostgreSQL (container postgres) -----------------------------------------
POSTGRES_USER=cais
POSTGRES_PASSWORD=sua_senha_postgres_aqui
POSTGRES_DB=cais_indicacoes

# Se a senha tiver @ : / # ? % & = use DATABASE_URL com senha codificada (URL encode)
# em vez de confiar só na montagem automática acima. Exemplo:
# DATABASE_URL=postgresql://cais:SENHA_CODIFICADA@postgres:5432/cais_indicacoes

# --- API (container api) -----------------------------------------------------
# Gerar secret: openssl rand -hex 32
JWT_SECRET=SUBSTITUA_POR_SECRET_ALEATORIO_32_BYTES_OU_MAIS
JWT_EXPIRES_IN=7d

# Origens permitidas no CORS (separadas por vírgula, sem espaços extras)
# Inclua a URL do frontend na Vercel e/ou domínio customizado
CORS_ORIGIN=https://seu-app.vercel.app,https://indicacoes.seudominio.com.br

MAX_UPLOAD_MB=10

# Token para a tela TV aplicar presets sem login (header X-TV-Token)
# Gerar: openssl rand -hex 24
# Deve ser o MESMO valor de VITE_TV_TOKEN no frontend (Vercel)
TV_API_TOKEN=SUBSTITUA_POR_TOKEN_TV_OPCIONAL

# --- Seed (obrigatório ao rodar `prisma db seed`) ---------------------------
# O container da API recebe estas variáveis do .env — necessárias no docker exec seed.
SEED_ADMIN_EMAIL=admin@seudominio.com.br
SEED_ADMIN_PASSWORD=SUBSTITUA_POR_SENHA_FORTE_DO_ADMIN

# --- pgAdmin (https://db.seudominio.com.br via Nginx Proxy Manager) -----------
PGADMIN_DEFAULT_EMAIL=admin@seudominio.com.br
PGADMIN_DEFAULT_PASSWORD=SUBSTITUA_POR_SENHA_FORTE_PGADMIN

# DATABASE_URL, PORT e NODE_ENV são definidos pelo docker-compose.prod.yml
# e não precisam ser repetidos aqui.
