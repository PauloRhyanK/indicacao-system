# Banco de dados (dev local usa o Postgres do docker-compose.dev.yml)
DATABASE_URL=postgresql://cais:cais_dev@localhost:5432/cais_indicacoes

# Autenticação
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Servidor
PORT=3001
NODE_ENV=development

# CORS — origens permitidas (separadas por vírgula) ou * para qualquer origem
# Dev local (Vite): http://localhost:8080
# Produção (frontend na Vercel): https://seu-app.vercel.app ou domínio customizado
CORS_ORIGIN=http://localhost:8080

# Upload de planilhas
MAX_UPLOAD_MB=10

# Credenciais usadas pelo seed (admin inicial — obrigatórias ao rodar prisma db seed)
SEED_ADMIN_EMAIL=admin@cais.local
SEED_ADMIN_PASSWORD=admin123

# Produção (VPS + Vercel): veja .env.production.example e apps/frontend/.env.production.example
