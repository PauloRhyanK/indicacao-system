# Banco de dados (dev local usa o Postgres do docker-compose.dev.yml)
DATABASE_URL=postgresql://cais:cais_dev@localhost:5432/cais_indicacoes

# Autenticação
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Servidor
PORT=3001
NODE_ENV=development

# CORS (origem do frontend em dev — Vite)
CORS_ORIGIN=http://localhost:5173

# Upload de planilhas
MAX_UPLOAD_MB=10

# Credenciais usadas pelo seed (admin inicial)
SEED_ADMIN_EMAIL=admin@cais.local
SEED_ADMIN_PASSWORD=admin123
